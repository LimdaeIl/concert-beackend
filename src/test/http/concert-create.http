### 공통 환경 변수
@host = http://localhost:8080
@venueUrl = {{host}}/api/v1/venues
@concertUrl = {{host}}/api/v1/concerts

@adminAccessToken = eyJhbGciOiJIUzUxMiJ9.eyJqdGkiOiI2MjBlZTRkNy1iMDJmLTQyMDQtYTgxNS0zNWU1ZWUzZGNhMmQiLCJzdWIiOiIxIiwidG9rZW5UeXBlIjoiYWNjZXNzIiwiaWF0IjoxNzgzNjcwMTA2LCJleHAiOjE3ODM2NzM3MDYsInJvbGUiOiJBRE1JTiJ9.hOcFlSZoDhz2zX66UVsjCP6ADo6WKL4h0RAQJm31t71vu-Q2erp_bP7_AywFRaoctrcy2OmxA6wfvG2o93bz4g


### 로그인 이후 받은 관리자 Access Token을 입력
###
POST http://localhost:8080/api/v1/auth/sign-up
Content-Type: application/json

{
  "email": "test@test.com",
  "password": "test1234!",
  "name": "test",
  "phone": "01012341234"
}


###
POST http://localhost:8080/api/v1/auth/sign-in
Content-Type: application/json

{
  "email": "test@test.com",
  "password": "test1234!"
}


###############################################################################
# Venue 생성 테스트
###############################################################################

### 1. 공연장 생성 성공
POST {{venueUrl}}
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "venueName": "올림픽공원",
  "address": "서울특별시 송파구 올림픽로 424",
  "detailAddress": "올림픽공원",
  "latitude": 37.5192,
  "longitude": 127.1158,
  "venueHalls": [
    {
      "hallName": "KSPO DOME",
      "capacity": 15000
    },
    {
      "hallName": "올림픽홀",
      "capacity": 2452
    }
  ]
}


### 2. 공연장 생성 실패 - 공연장 이름 누락
POST {{venueUrl}}
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "venueName": "",
  "address": "서울특별시 송파구 올림픽로 424",
  "detailAddress": "올림픽공원",
  "latitude": 37.5192,
  "longitude": 127.1158,
  "venueHalls": [
    {
      "hallName": "KSPO DOME",
      "capacity": 15000
    }
  ]
}


