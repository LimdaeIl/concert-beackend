###############################################################################
# Concert 생성 성공 테스트
#
# 주의:
# venueHallId는 위 공연장 생성 성공 응답으로 받은 실제 홀 ID로 변경해야 합니다.
###############################################################################

### 8. 콘서트 생성 성공 - 스케줄 2개, 이미지 2개
POST {{concertUrl}}
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "title": "2026 여름 콘서트",
  "description": "2026년 여름에 진행되는 콘서트입니다.",
  "organizer": "Concert Company",
  "category": "BAND",
  "schedules": [
    {
      "venueHallId": 1,
      "performanceAt": "2026-08-20T19:00:00",
      "bookingStartAt": "2026-07-20T12:00:00",
      "bookingEndAt": "2026-08-20T17:00:00"
    },
    {
      "venueHallId": 1,
      "performanceAt": "2026-08-21T18:00:00",
      "bookingStartAt": "2026-07-20T12:00:00",
      "bookingEndAt": "2026-08-21T16:00:00"
    }
  ],
  "images": [
    {
      "imageUrl": "https://example.com/images/concert-main.jpg",
      "sortOrder": 0,
      "representative": true
    },
    {
      "imageUrl": "https://example.com/images/concert-detail.jpg",
      "sortOrder": 1,
      "representative": false
    }
  ]
}


### 9. 콘서트 생성 성공 - 같은 시간, 서로 다른 홀
POST {{concertUrl}}
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "title": "멀티홀 콘서트",
  "description": "같은 시간에 서로 다른 홀을 사용하는 테스트입니다.",
  "organizer": "Concert Company",
  "category": "ROCK",
  "schedules": [
    {
      "venueHallId": 1,
      "performanceAt": "2026-09-01T19:00:00",
      "bookingStartAt": "2026-08-01T12:00:00",
      "bookingEndAt": "2026-09-01T17:00:00"
    },
    {
      "venueHallId": 2,
      "performanceAt": "2026-09-01T19:00:00",
      "bookingStartAt": "2026-08-01T12:00:00",
      "bookingEndAt": "2026-09-01T17:00:00"
    }
  ],
  "images": [
    {
      "imageUrl": "https://example.com/images/multi-hall.jpg",
      "sortOrder": 0,
      "representative": true
    }
  ]
}


