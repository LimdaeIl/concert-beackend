      "venueHallId": 1,
      "performanceAt": "2026-08-20T19:00:00",
      "bookingStartAt": "2026-07-20T12:00:00",
      "bookingEndAt": "2026-08-20T17:00:00"
    }
  ],
  "images": [
    {
      "imageUrl": "https://example.com/images/main.jpg",
      "sortOrder": 0,
      "representative": true
    }
  ]
}


### 26. 콘서트 생성 실패 - 일반 회원 Access Token
# 아래 토큰을 실제 MEMBER 권한 Access Token으로 변경
POST {{concertUrl}}
Authorization: Bearer MEMBER_ACCESS_TOKEN
Content-Type: application/json

{
  "title": "권한 없는 콘서트",
  "description": "ADMIN 권한 검증 테스트",
  "organizer": "Concert Company",
  "category": "BAND",
  "schedules": [
    {
      "venueHallId": 1,
      "performanceAt": "2026-08-20T19:00:00",
      "bookingStartAt": "2026-07-20T12:00:00",
      "bookingEndAt": "2026-08-20T17:00:00"
    }
  ],
  "images": [
    {
      "imageUrl": "https://example.com/images/main.jpg",
      "sortOrder": 0,
      "representative": true
    }
  ]
}