### 24. 콘서트 생성 실패 - 예매 종료와 공연 시각이 같음
# 현재 도메인 규칙:
# bookingEndAt < performanceAt
# 따라서 두 시각이 같으면 실패해야 함
POST {{concertUrl}}
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "title": "예매 종료와 공연 시각이 같은 콘서트",
  "description": "예매 종료와 공연 시각 동일 조건 테스트",
  "organizer": "Concert Company",
  "category": "BALLADE",
  "schedules": [
    {
      "venueHallId": 1,
      "performanceAt": "2026-08-20T19:00:00",
      "bookingStartAt": "2026-07-20T12:00:00",
      "bookingEndAt": "2026-08-20T19:00:00"
    }
  ],
  "images": [
    {
      "imageUrl": "https://example.com/images/main.jpg",
      "sortOrder": 0,
      "representative": true
    }
  ]
}


